{
  "manifest_version": 3,
  "name": "Vocabulary Helper Extension",
  "version": "0.1.1",
  "description": "Capture selected words, query definitions via Definer and record into Notion after delay.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["contextMenus", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://api.notion.com/*",
    "https://lumetrium.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
